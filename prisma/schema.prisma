generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  role         String   // member, coach, staff, division_manager, executive_manager
  division     String?  // academy, pro_shop, grill, driving_range, greens, operations
  passwordHash String
  memberSince     DateTime @default(now())
  experience      String?  // beginner, intermediate, advanced, expert
  stripeCustomerId String? // Stripe Customer ID for saved payment methods
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings      Booking[]
  grillOrders   GrillOrder[]
  notifications UserNotification[]
  transactions  Transaction[]
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  title     String
  email     String   @unique
  division  String
  shift     String?
  status    String   @default("active") // active, off-duty, on-leave
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coach {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  bio            String
  specialties    String   // JSON array stored as string
  certifications String   // JSON array stored as string
  rating         Float    @default(0)
  lessonsGiven   Int      @default(0)
  hourlyRate     Float
  availability   String   // JSON array stored as string
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  classes AcademyClass[]
}

model MembershipPlan {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  interval    String   // monthly, annual, semester
  features    String   // JSON array stored as string
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AcademyClass {
  id          String   @id @default(cuid())
  name        String
  description String
  coachId     String
  ageGroup    String
  skillLevel  String
  schedule    String
  spotsTotal  Int
  spotsFilled Int      @default(0)
  price       Float
  location    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach Coach @relation(fields: [coachId], references: [id])
}

model TeeTime {
  id         String   @id @default(cuid())
  date       String
  time       String
  players    Int      @default(0)
  maxPlayers Int      @default(4)
  status     String   @default("available") // available, booked, blocked
  bookedBy   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bookings Booking[]
}

model ScheduleSettings {
  id           String   @id // single row: "default"
  firstTeeTime String   @default("7:00 AM")
  lastTeeTime  String   @default("5:00 PM")
  updatedAt    DateTime @updatedAt
}

model PrivateEvent {
  id        String   @id @default(cuid())
  date      String
  startTime String
  endTime   String
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  teeTimeId String?
  type      String   // tee_time, lesson, class, grill_order
  status    String   @default("confirmed") // confirmed, cancelled, completed
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  teeTime TeeTime? @relation(fields: [teeTimeId], references: [id])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String   // appetizer, entree, sandwich, beverage, snack, beer, liquor
  available   Boolean  @default(true)
  popular     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GrillOrder {
  id                   String   @id @default(cuid())
  userId               String?  // optional for guest checkout
  items                String   // JSON: [{ menuItemId, name, price, quantity }]
  totalCents           Int      // total in cents for Stripe
  fulfillment          String   // pickup | deliver_to_cart
  stripePaymentIntentId String?
  stripeCustomerId     String?
  status               String   @default("pending") // pending, paid, preparing, ready, completed, cancelled
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  category     String
  quantity     Int
  reorderLevel Int
  price        Float
  division     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String?
  date        String
  description String
  amount      Float
  type        String   // payment, refund, commission
  status      String   @default("completed") // completed, pending, failed
  division    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // info, warning, success, billing
  global    Boolean  @default(false)
  createdAt DateTime @default(now())

  userNotifications UserNotification[]
}

model UserNotification {
  id             String   @id @default(cuid())
  userId         String
  notificationId String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  notification Notification @relation(fields: [notificationId], references: [id])

  @@unique([userId, notificationId])
}

model GreensFee {
  id          String   @id @default(cuid())
  category    String   // regular, senior, junior, tjga, weekend
  description String
  price       Float
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RangeFee {
  id          String   @id @default(cuid())
  size        String   // small, medium, large
  balls       Int
  price       Float
  memberPrice Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseCondition {
  id        String   @id @default(cuid())
  area      String
  condition String
  speed     String?
  details   String?
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model MaintenanceTask {
  id        String   @id @default(cuid())
  task      String
  assignee  String
  status    String   @default("scheduled") // scheduled, in_progress, completed
  priority  String   @default("medium") // low, medium, high
  dueDate   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
